# dependencies / builds
node_modules/
dist/
*.local

# datasets are never committed (see docs/DATASET.md)
data/

# python
__pycache__/
*.pyc
.venv/

# large model weights — distributed via GitHub Releases, not git
*.h5
*.keras

# self-hosted MediaPipe runtime assets — fetched by web/scripts/fetch-models.mjs
# (wasm comes from the npm package; .task models from Google's pinned storage)
web/public/wasm/
web/public/models/*.task

# editor / os
.vscode/*
!.vscode/extensions.json
.idea/
.DS_Store
Thumbs.db

# logs
*.log
npm-debug.log*
